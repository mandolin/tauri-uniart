{
  "name": "tauri-uniart",
  "private": true,
  "version": "0.1.0-beta.1",
  "description": "UnicodeArt App desktop Unicode character art workstation.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/project.test.ts",
    "release:verify": "node scripts/verify-release-contract.mjs",
    "check": "npm run typecheck && npm run test && vite build && npm run release:verify",
    "evidence": "pwsh -NoLogo -NoProfile -File scripts/prepare-compatible-evidence.ps1",
    "installer:fixture": "pwsh -NoLogo -NoProfile -File scripts/build-nsis-upgrade-fixture.ps1",
    "installer:smoke": "pwsh -NoLogo -NoProfile -File scripts/smoke-nsis-installer.ps1",
    "sandbox:prepare": "pwsh -NoLogo -NoProfile -File scripts/prepare-windows-sandbox.ps1",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:binary": "tauri build --no-bundle"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "unicode-art-js": "^1.2.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "tsx": "^4.23.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
