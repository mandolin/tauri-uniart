{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "主窗口仅可通过原生对话框选择文件，并对该次选择临时授权的路径读写；草稿仅保存到应用私有目录。",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/workspace-state.json"
        }
      ]
    }
  ]
}
